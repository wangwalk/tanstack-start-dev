# Cloudflare D1 — local dev uses the D1 simulator via @cloudflare/vite-plugin (no config needed).
# These are only required for drizzle-kit remote operations (generate/push/pull via d1-http driver).
# Get values from: https://dash.cloudflare.com → Workers & Pages → D1
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

BETTER_AUTH_URL=
BETTER_AUTH_SECRET=

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM="TanStack Start <noreply@yourdomain.com>"

# Newsletter — Resend Audiences (default provider)
# Create an audience at: https://resend.com/audiences
RESEND_AUDIENCE_ID=

# Newsletter — Beehiiv (optional alternative provider)
# Set NEWSLETTER_PROVIDER=beehiiv to use Beehiiv instead of Resend Audiences
# NEWSLETTER_PROVIDER=beehiiv
# BEEHIIV_API_KEY=
# BEEHIIV_PUBLICATION_ID=

# OAuth (GitHub)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_CREDITS_STARTER=price_...
STRIPE_PRICE_CREDITS_GROWTH=price_...
STRIPE_PRICE_CREDITS_PRO=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare Turnstile (captcha)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# Leave unset to disable captcha in local dev
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Analytics — all providers are opt-in; leave unset to disable
# PostHog (https://posthog.com) — recommended default
POSTHOG_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Umami (https://umami.is) — self-hosted, privacy-first
UMAMI_WEBSITE_ID=
UMAMI_SRC=https://cloud.umami.is/script.js

# Plausible (https://plausible.io) — lightweight, GDPR-compliant
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Google Analytics 4
GA4_MEASUREMENT_ID=G-...

# OpenPanel (https://openpanel.dev) — open source PostHog alternative
OPENPANEL_CLIENT_ID=
OPENPANEL_API_URL=https://api.openpanel.dev
